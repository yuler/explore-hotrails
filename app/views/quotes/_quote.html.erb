<div class="card bg-base-100 shadow-sm border border-base-300">
  <div class="card-body p-4">
    <div class="flex justify-between items-center">
      <div class="flex-1">
        <%= link_to quote.name, quote_path(quote), class: "text-lg font-medium hover:text-primary transition-colors" %>
      </div>
      <div class="flex gap-2 ml-4">
        <%= link_to "edit", edit_quote_path(quote), class: "btn btn-sm btn-ghost" %>
        <%= link_to "delete", quote_path(quote), class: "btn btn-sm btn-ghost text-error hover:bg-error hover:text-error-content", data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
      </div>
    </div>
  </div>
</div>
